# ============================================================
# 项目运行时产物（报告 / 日志 / 会话目录）
# ============================================================
# HTML 报告与用例执行会话目录（程序生成，勿提交）
reports/
logs/
logs/**
*.session.json

# 运行时配置（含本地真实串口/FTP 等环境信息，按需在根目录覆盖）
atprobe.yaml
env.yaml
# 但 examples/ 下的同名样例文件保留
!examples/**
!examples/**/atprobe.yaml
!examples/**/env.yaml

# 临时/调试产物
_*.bat
_*.txt
_smoke*.py
tmp/
tmp_*
*.tmp
*.bak
*.swp
*~

# Windows 重定向产生的误生成文件
nul

